APP_URL=http://localhost:3000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB"
AUTH_SECRET="replace-with-strong-random-string"
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Auth providers — enable at least one. Each provider activates automatically
# when both of its env vars are present.

# Google OAuth (primary) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic links via Resend — https://resend.com/api-keys
# EMAIL_FROM must be a verified sender on your Resend domain.
RESEND_API_KEY=""
EMAIL_FROM="TruDocket <no-reply@your-domain.com>"

# GitHub OAuth (secondary / dev-friendly)
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_MONTHLY_ID="price_..."

# Optional AI / external service keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
COURLISTENER_API_TOKEN=""
